# === Telegram Bot ===
BOT_TOKEN=your-telegram-bot-token

# Admin Telegram IDs (comma-separated)
ADMIN_IDS=123456789,987654321

# === Database ===
DATABASE_URL=sqlite+aiosqlite:///bot.db
# For production use PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/bot

# === Image Generation ===
# Provider: dalle | flux
IMAGE_PROVIDER=dalle

# OpenAI (for DALL-E 3)
OPENAI_API_KEY=sk-...

# Replicate (for Flux Schnell)
REPLICATE_API_TOKEN=r8_...

# Mock mode (use fake images for testing)
MOCK_MODE=0

# === YooKassa Payments ===
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-secret-key
YOOKASSA_WEBHOOK_SECRET=your-webhook-secret

# === Security ===
API_KEY=your-secret-key-here

# === Webhook (for YooKassa notifications) ===
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000
WEBHOOK_BASE_URL=https://your-domain.com
